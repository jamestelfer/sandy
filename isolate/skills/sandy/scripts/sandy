#!/bin/bash
#
# Sandy: sandboxed TypeScript execution environment for AI agents.
# Wraps Shuru ephemeral microVMs with Node.js, AWS SDK, and tsc.

set -euo pipefail

readonly CHECKPOINT_NAME='sandy'
readonly DEFAULT_REGION='us-west-2'
readonly VM_WORKSPACE='/workspace'
readonly VM_SCRIPTS_DIR="${VM_WORKSPACE}/scripts"
readonly VM_OUTPUT_DIR="${VM_WORKSPACE}/output"
readonly VM_BOOTSTRAP='/tmp/bootstrap'

# Print error message to STDERR and exit.
err() {
  echo "sandy: $*" >&2
  exit 1
}

# Print usage information to STDERR.
usage() {
  cat >&2 <<EOF
Usage: sandy <command> [options]

Commands:
  run                 Run a TypeScript script in a sandboxed VM
  check baseline      Verify VM packages and output writes
  check connect       Verify AWS connectivity (requires --imds-port)
  snapshot create     Create the sandy VM snapshot
  snapshot list       List available snapshots
  snapshot delete     Delete the sandy snapshot
Run options:
  --script <path>     Path to TypeScript file to execute (required)
  --imds-port <port>  IMDS server port on the host (required)
  --region <region>   AWS region (default: us-west-2)
  --output-dir <dir>  Host directory for script output
  --session <id>      Session ID for default output directory naming
  -- [args...]        Arguments to pass through to the script
EOF
}

# create a staging directory for files from the skill that need to be mounted
# into the VM, such as the bootstrap files. Shuru requires that mounted directories
# are subdirectories of the current working directory.
staging_sub_dir() {
  local sub_dir="$1"

  local staging_dir=".sandy/${sub_dir}"
  rm -rf "${staging_dir}"
  mkdir -p "${staging_dir}"

  local script_dir
  script_dir="$(cd "$(dirname "$0")" && pwd)"

  local source_dir
  source_dir="${script_dir}/${sub_dir}"

  if [[ ! -d "${source_dir}" ]]; then
    err "${sub_dir} directory not found: ${source_dir}"
  fi

  local staging_dir=".sandy/${sub_dir}"
  rm -rf "${staging_dir}"
  mkdir -p "${staging_dir}/certs"
  cp -R "${source_dir}/." "${staging_dir}/"

  echo "${staging_dir}"
}

# Create the sandy Shuru checkpoint with Node.js, pnpm, AWS SDK, and tsc.
snapshot_create() {
  # Stage bootstrap files in .sandy/ (within cwd, mountable by shuru)
  local staging_dir
  staging_dir="$(staging_sub_dir "bootstrap")"
  mkdir -p "${staging_dir}/certs"

  # Copy Netskope MitM cert if available
  local netskope_src
  netskope_src="/Library/Application Support/Netskope/STAgent/data"
  netskope_src="${netskope_src}/nscacert.pem"
  if [[ -f "${netskope_src}" ]]; then
    cp "${netskope_src}" "${staging_dir}/certs/nscacert.pem"
    echo "sandy: Netskope certificate staged for installation" >&2
  else
    echo "sandy: warning: Netskope certificate not found, skipping" >&2
  fi

  echo "Creating sandy snapshot..." >&2

  shuru checkpoint create "${CHECKPOINT_NAME}" --allow-net \
    --mount "${staging_dir}:${VM_BOOTSTRAP}" \
    -- sh "${VM_BOOTSTRAP}/init.sh"

  echo "Snapshot created." >&2
}

# List available Shuru checkpoints.
snapshot_list() {
  shuru checkpoint list
}

# Delete the sandy Shuru checkpoint.
snapshot_delete() {
  shuru checkpoint delete "${CHECKPOINT_NAME}"
}

# Dispatch snapshot subcommands.
snapshot() {
  local subcommand="${1:-}"
  case "${subcommand}" in
    create) snapshot_create ;;
    list) snapshot_list ;;
    delete) snapshot_delete ;;
    *)
      err "unknown snapshot command: ${subcommand}"
      ;;
  esac
}

# Run a TypeScript script inside the sandboxed VM.
run() {
  if ! shuru checkpoint list 2>/dev/null \
      | grep -q "^${CHECKPOINT_NAME} "; then
    err "checkpoint '${CHECKPOINT_NAME}' not found. Run: sandy snapshot create"
  fi

  local script_path=''
  local imds_port=''
  local region="${DEFAULT_REGION}"
  local output_dir=''
  local session=''
  local script_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --script)
        script_path="$2"
        shift 2
        ;;
      --imds-port)
        imds_port="$2"
        shift 2
        ;;
      --region)
        region="$2"
        shift 2
        ;;
      --output-dir)
        output_dir="$2"
        shift 2
        ;;
      --session)
        session="$2"
        shift 2
        ;;
      --)
        shift
        script_args=("$@")
        break
        ;;
      *)
        err "unrecognised argument: $1"
        ;;
    esac
  done

  if [[ -z "${script_path}" ]]; then
    err "missing required flag: --script <path>"
  fi

  if [[ -z "${imds_port}" ]]; then
    err "missing required flag: --imds-port <port>"
  fi

  if [[ ! -f "${script_path}" ]]; then
    err "script not found: ${script_path}"
  fi

  if [[ -z "${output_dir}" ]]; then
    local session_id
    session_id="${session:-$(date +%Y%m%d-%H%M%S)-$$}"
    output_dir=".sandy/${session_id}"
  fi

  mkdir -p "${output_dir}" \
    || err "failed to create output directory: ${output_dir}"
  echo "sandy: output directory: ${output_dir}" >&2

  local script_dir
  script_dir="$(cd "$(dirname "${script_path}")" && pwd)"
  local script_name
  script_name="$(basename "${script_path}")"

  local imds_url="http://10.0.0.1:${imds_port}"

  shuru run \
    --from "${CHECKPOINT_NAME}" \
    --allow-net \
    --expose-host "${imds_port}" \
    --allow-host '*.amazonaws.com' \
    --allow-host '*.aws.amazon.com' \
    --allow-host-writes \
    --mount "${script_dir}:${VM_SCRIPTS_DIR}" \
    --mount "${output_dir}:${VM_OUTPUT_DIR}:rw" \
    -- env \
      "AWS_EC2_METADATA_SERVICE_ENDPOINT=${imds_url}" \
      "AWS_EC2_METADATA_SERVICE_ENDPOINT_MODE=IPv4" \
      "AWS_EC2_METADATA_V1_DISABLED=true" \
      "AWS_REGION=${region}" \
      "SANDY_OUTPUT=${VM_OUTPUT_DIR}" \
      sh -l -c "cd ${VM_WORKSPACE} && pnpm run typecheck && pnpm run invoke -- \
        ${VM_WORKSPACE}/dist/scripts/${script_name%.ts}.js \$*" \
      _ "${script_args[@]+"${script_args[@]}"}"
}

# Run the baseline health check (no AWS credentials needed).
check_baseline() {
  if ! shuru checkpoint list 2>/dev/null \
      | grep -q "^${CHECKPOINT_NAME} "; then
    err "checkpoint '${CHECKPOINT_NAME}' not found. Run: sandy snapshot create"
  fi

  local checks_dir
  checks_dir="$(staging_sub_dir "checks")"

  local output_dir="${checks_dir}/baseline-$$"
  mkdir -p "${output_dir}"

  echo "sandy: running baseline check..." >&2

  shuru run \
    --from "${CHECKPOINT_NAME}" \
    --allow-host-writes \
    --mount "${checks_dir}:${VM_SCRIPTS_DIR}" \
    --mount "${output_dir}:${VM_OUTPUT_DIR}:rw" \
    -- env \
      "SANDY_OUTPUT=${VM_OUTPUT_DIR}" \
      sh -l -c "cd ${VM_WORKSPACE} && pnpm run typecheck && pnpm run invoke -- \
        ${VM_WORKSPACE}/dist/scripts/baseline.js" \
      _

  if [[ -f "${output_dir}/baseline.json" ]]; then
    echo "sandy: baseline check PASSED (output written)" >&2
  else
    echo "sandy: baseline check FAILED (no output file)" >&2
    rm -rf "${output_dir}"
    exit 1
  fi

  rm -rf "${output_dir}"
}

# Run the connectivity check with AWS credentials.
check_connect() {
  if ! shuru checkpoint list 2>/dev/null \
      | grep -q "^${CHECKPOINT_NAME} "; then
    err "checkpoint '${CHECKPOINT_NAME}' not found. Run: sandy snapshot create"
  fi

  local imds_port=''
  local region="${DEFAULT_REGION}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --imds-port)
        imds_port="$2"
        shift 2
        ;;
      --region)
        region="$2"
        shift 2
        ;;
      *)
        err "unrecognised argument: $1"
        ;;
    esac
  done

  if [[ -z "${imds_port}" ]]; then
    err "missing required flag: --imds-port <port>"
  fi

  local checks_dir
  checks_dir="$(staging_sub_dir "checks")"

  local imds_url="http://10.0.0.1:${imds_port}"

  echo "sandy: running connectivity check..." >&2

  shuru run \
    --from "${CHECKPOINT_NAME}" \
    --allow-net \
    --expose-host "${imds_port}" \
    --allow-host '*.amazonaws.com' \
    --allow-host '*.aws.amazon.com' \
    --mount "${checks_dir}:${VM_SCRIPTS_DIR}" \
    -- env \
      "AWS_EC2_METADATA_SERVICE_ENDPOINT=${imds_url}" \
      "AWS_EC2_METADATA_SERVICE_ENDPOINT_MODE=IPv4" \
      "AWS_EC2_METADATA_V1_DISABLED=true" \
      "AWS_REGION=${region}" \
      sh -l -c "cd ${VM_WORKSPACE} && pnpm run typecheck && pnpm run invoke -- \
        ${VM_WORKSPACE}/dist/scripts/connect.js" \
      _
}

# Dispatch check subcommands.
check() {
  local subcommand="${1:-}"
  case "${subcommand}" in
    baseline) check_baseline ;;
    connect)
      shift
      check_connect "$@"
      ;;
    *)
      err "unknown check command: ${subcommand}. Use: baseline, connect"
      ;;
  esac
}

# Ensure the .sandy working directory exists with a .gitignore.
ensure_sandy_dir() {
  mkdir -p .sandy
  if [[ ! -f .sandy/.gitignore ]]; then
    echo '*' > .sandy/.gitignore
  fi
}

# Entry point.
main() {
  ensure_sandy_dir

  local command="${1:-}"

  case "${command}" in
    snapshot)
      shift
      snapshot "$@"
      ;;
    run)
      shift
      run "$@"
      ;;
    check)
      shift
      check "$@"
      ;;
    help | --help | -h) usage ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
