{
  "name": "sandy",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sandy": "./dist/sandy"
  },
  "scripts": {
    "build": "bun build --compile --target=bun src/main.ts --outfile dist/sandy",
    "build:all": "bunli build",
    "test": "bun test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix --unsafe .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "agent": "bun run lint:fix && bun run format:fix && bun run build && bun run test",
    "integration": "INTEGRATION=true bun test --testPathPattern integration",
    "integration:docker": "INTEGRATION=true bun test src/docker-backend.integration.test.ts",
    "integration:shuru": "INTEGRATION=true bun test src/shuru-backend.integration.test.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@superhq/shuru": "^0.4.2",
    "dockerode": "^4.0.10",
    "human-id": "^4.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/dockerode": "^4.0.1",
    "@types/yargs": "^17.0.35",
    "bunli": "^0.9.1",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3"
  }
}
